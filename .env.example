# Safe local-only environment example for Django Chat.
# Copy values into a private .env file when you need local overrides.

DJANGO_READ_DOT_ENV_FILE=True
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-for-local-development-only

# manage.py defaults to config.settings.local; pytest uses config.settings.test.
# DJANGO_SETTINGS_MODULE=config.settings.local

# Used by Wagtail when it needs to generate absolute admin URLs.
# DJANGO_CHAT_WAGTAIL_ADMIN_BASE_URL=http://localhost:8000/cms/

# SQLite is the default when DATABASE_URL is unset.
# DATABASE_URL=sqlite:///db.sqlite3
