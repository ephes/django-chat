# Safe local-only environment example for Django Chat.
# Copy values into a private .env file when you need local overrides.

DJANGO_READ_DOT_ENV_FILE=True
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-for-local-development-only

# manage.py defaults to config.settings.local; pytest uses config.settings.test.
# DJANGO_SETTINGS_MODULE=config.settings.local

# Used by Wagtail when it needs to generate absolute admin URLs.
# DJANGO_CHAT_WAGTAIL_ADMIN_BASE_URL=http://localhost:8000/cms/

# Default Wagtail Site hostname/port, applied by `manage.py ensure_default_site`
# (it does not read these at settings-load time — run the command after setting
# them). The seeded dev Site is localhost:80, which drops the :8000 runserver
# port from canonical/OG URLs; set these and run the command so those URLs
# resolve on the dev server:
#   manage.py ensure_default_site --hostname localhost --port 8000
# DJANGO_CHAT_SITE_HOSTNAME=localhost
# DJANGO_CHAT_SITE_PORT=8000

# Enable django-cast comments on episode/post pages (default off). Set to true
# per-environment to switch comments on (e.g. on staging). Comments are also
# gated per object in the Wagtail admin (comments_enabled on the podcast and
# episode), so this flag alone does not surface them — see docs/local-development.md.
# CAST_COMMENTS_ENABLED=false

# Let comment authors edit/delete their own still-public, unanswered comments
# from the same browser session. Default off per environment; the local settings
# turn it on for development. Requires a server-side session backend (the project
# default DB-backed sessions qualify; the signed_cookies backend is rejected).
# CAST_COMMENTS_ALLOW_AUTHOR_EDITS=false

# Deployment renders these into the target .env through Ansible/SOPS. They are
# shown here only so local production-settings smoke checks can use safe values.
# DJANGO_ALLOWED_HOSTS=django-chat.example.invalid,localhost
# DJANGO_ADMIN_URL=django-admin/
# DJANGO_CHAT_WAGTAIL_ADMIN_PATH=cms/

# SQLite is the default when DATABASE_URL is unset.
# DATABASE_URL=sqlite:///db.sqlite3

# Media storage defaults to the local filesystem. Set this to "s3" only when
# you have a Django Chat-specific S3-compatible bucket and credentials.
# DJANGO_CHAT_MEDIA_STORAGE_BACKEND=s3
# DJANGO_CHAT_S3_ACCESS_KEY_ID=change-me
# DJANGO_CHAT_S3_SECRET_ACCESS_KEY=change-me
# DJANGO_CHAT_S3_STORAGE_BUCKET_NAME=django-chat-media
# DJANGO_CHAT_S3_ENDPOINT_URL=https://s3.example.com
# DJANGO_CHAT_S3_REGION_NAME=eu-central-1
# DJANGO_CHAT_S3_CUSTOM_DOMAIN=media.djangochat.example.com
# DJANGO_CHAT_MEDIA_URL=https://media.djangochat.example.com/
# DJANGO_CHAT_S3_ADDRESSING_STYLE=virtual
# DJANGO_CHAT_S3_SIGNATURE_VERSION=s3v4
# DJANGO_CHAT_S3_QUERYSTRING_AUTH=False
# DJANGO_CHAT_S3_FILE_OVERWRITE=False
# DJANGO_CHAT_S3_DEFAULT_ACL=
# DJANGO_CHAT_S3_CACHE_CONTROL=max-age=604800, s-maxage=604800, must-revalidate
#
# When S3 media is enabled, settings also bind
# STORAGES["cast_public_transcripts"] to the same S3 bucket/media host. This
# keeps public django-cast transcript artifacts on durable public media storage.
# STORAGES["cast_voice_references"] uses the same bucket/keyspace without the
# public media host, with signed private defaults, so known-speaker sidecars and
# voice-reference clips are not migrated to local disk.
